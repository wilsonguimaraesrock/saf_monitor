# ============================================================
# SISTEMA DE MONITORAMENTO DE SAFs — TEMPLATE DE VARIÁVEIS
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no git.
# ============================================================

# --- Credenciais do sistema SAF (dfranquias) ---
SAF_BASE_URL=https://app.dfranquias.com.br
SAF_LOGIN_URL=https://app.dfranquias.com.br/login
SAF_LIST_URL=https://app.dfranquias.com.br/saf/
SAF_USERNAME=wade.venga@rockfeller.com.br
SAF_PASSWORD=wade2025@

# --- Banco de dados PostgreSQL (Digital Ocean Managed Database) ---
# Encontre no painel DO: Databases → seu banco → Connection Details
# Formato: postgresql://usuario:senha@host:porta/nome_banco?sslmode=require
DATABASE_URL=postgresql://doadmin:SENHA@host.db.ondigitalocean.com:25060/defaultdb?sslmode=require
DATABASE_SSL=true
# Opcional: path para o CA certificate baixado do painel DO
# DB_SSL_CA_PATH=./certs/do-ca-certificate.crt

# --- Telegram Bot (notificações) ---
# Setup em 2 min — veja instruções em src/integrations/notifications.ts
TELEGRAM_BOT_TOKEN=123456789:AAF_seu_token_aqui
TELEGRAM_CHAT_ID=987654321

# --- OpenAI (agrupamento semântico — OPCIONAL) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Scheduler ---
CRON_MORNING=0 8 * * 1-5
CRON_MIDDAY=0 13 * * 1-5
CRON_AFTERNOON=0 17 * * 1-5
CRON_SECRET=troque_por_uma_string_secreta_forte

# --- Alertas — limiares configuráveis ---
ALERT_OVERDUE_MIN=1
ALERT_AWAITING_DAYS_THRESHOLD=3
ALERT_OLDEST_TOP_N=10
ALERT_VOLUME_SPIKE_PERCENT=20

# --- Configuração geral ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
LOG_DIR=./logs

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_SCREENSHOT_ON_ERROR=true
SCREENSHOT_DIR=./logs/screenshots
SCRAPER_MAX_PAGES=50
